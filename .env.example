# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
PG_HOST=db
PG_PORT=5432
PG_DB=scheduler_db
PG_USER=scheduler_user
PG_PASS=scheduler_pass

# Message Queue and Cache
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# UI Configuration
UI_PORT=9000
NODE_ENV=production

# Security (generate your own for production)
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# CORS (for production, set to your domain)
CORS_ORIGINS=http://localhost:9000,http://localhost:3000